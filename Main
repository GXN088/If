public class Main {
    public static void main(String[] args) {
        int a = 10;
        int b = 10;
        
        // Не изменяйте ничего ниже этой строки
        int c = 0;
        if (a >= b && !(b < 10)) {
            c = 2;
        }
        
        c += 1;
        System.out.println("c = " + c);
    }
}
